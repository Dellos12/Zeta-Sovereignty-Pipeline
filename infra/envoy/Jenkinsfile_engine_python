
pipeline {
    agent any
    stages {
        stage('Subir Engine Python') {
            steps {
                script {
                    sh 'cd /workspace && docker-compose --profile pipeline up -d engine_python'
                }
            }
        }
    }
    post {
        always {
            sh 'cd /workspace && docker-compose stop engine_python || true'
        }
    }
}
