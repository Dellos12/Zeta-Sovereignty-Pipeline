pipeline {
    agent any

    environment {
        // Credenciais e Repositório
        GIT_CRED_ID = 'github-token-zeta'
        REPO_URL    = 'https://github.com/Dellos12/Zeta-Sovereignty-Pipeline'

        // Pasta do app dentro do Git
        PASTA_RUBY  = "Manifold" 
        
        // REDE: Ajustada para o nome que o Docker Compose cria (sem o prefixo de workspace)
        REDE_REAL   = "ressonancia_net"

        // Variáveis de Soberania
        DB_HOST     = "db_vector"
        DB_USER     = "postgres"
        DB_PASSWORD = "password"
        DB_NAME     = "manifold_development"
        REDIS_URL   = "redis://redis:6379/1"
        RAILS_ENV   = "production"

        // Chave de Segurança (Mantenha em segredo)
        SECRET_KEY_BASE = "985a78449a9aae6915132f82beb29355399444bb33925abf80679a72c572d99673a8a390ebca8d48a6a78d531b5264cb5e48b6f2e1cf5996b8140d0505450efb"
    }

    stages {
        stage('1. Sincronização da Malha Oficial') {
            steps {
                echo "--- Limpando Conflitos e Subindo Infra (DB, Redis, Engine) ---"
                // --force-recreate mata containers "pendurados"
                // --remove-orphans limpa o manifold_app caso ele tenha ficado no perfil antigo
                sh 'docker compose --profile pipeline up -d --force-recreate --remove-orphans'
            }
        }

        stage('2. Acoplamento e Injeção de Segurança') {
            steps {
                dir("${PASTA_RUBY}") {
                    echo "--- Reconstruindo a Peça Ruby (Manifold) ---"
                    sh 'docker build -t manifold_underground .'

                    echo "--- DEBUG: Validando instalação do Rails na Imagem ---"
                    sh 'docker run --rm manifold_underground ls -la /rails/bin/rails'
                }
                
                script {
                    echo "--- Resetando e Alinhando Container Manifold ---"
                    // Remove qualquer container antigo para evitar o erro "Conflict"
                    sh 'docker rm -f manifold_app || true'
                    
                    // SEM VOLUME (-v) para usar o Rails instalado no Dockerfile
                    sh """
                        docker run -d --name manifold_app \
                        --network ${REDE_REAL} \
                        -u root \
                        -w /rails \
                        -e DB_HOST=${DB_HOST} \
                        -e DB_USER=${DB_USER} \
                        -e DB_PASSWORD=${DB_PASSWORD} \
                        -e DB_NAME=${DB_NAME} \
                        -e REDIS_URL=${REDIS_URL} \
                        -e RAILS_ENV=${RAILS_ENV} \
                        -e SECRET_KEY_BASE=${SECRET_KEY_BASE} \
                        --entrypoint /bin/bash \
                        manifold_underground -c "chmod +x bin/rails && tail -f /dev/null"
                    """
                }
            }
        }

        stage('3. Prontidão para o Console Zeta') {
            steps {
                echo "--- ENGRENAGEM ALINHADA E BLINDADA ---"
                // Teste final de conectividade
                sh 'docker exec manifold_app bin/rails -v'
                
                echo "Container rodando: Rails 8.1.3 detectado."
                echo "ACESSO AO CONSOLE: docker exec -it manifold_app bin/rails c"
            }
        }
    }
}

