pipeline {
    agent any
    
    environment {
        // Credencial 'github-token-zeta' deve ser 'Username with password'
        GIT_CRED_ID = 'github-token-zeta'
        REPO_URL = 'https://github.com/Dellos12/Zeta-Sovereignty-Pipeline'
    }

    stages {
        stage('🧬 Clonagem e Sincronia') {
            steps {
                // Sincroniza o DNA do projeto
                checkout scm
            }
        }

        stage('🔥 Ignição do Reator') {
            steps {
                script {
                    echo "🧹 Limpando resíduos de builds anteriores (Preservando Auditor Supremo)..."
                    // Para e remove apenas os operários, mantendo o Jenkins (Auditor) vivo
                    sh 'docker-compose stop engine_python transport_go envoy redis db_vector rabbitmq || true'
                    sh 'docker-compose rm -f engine_python transport_go envoy redis db_vector rabbitmq || true'
                    
                    echo "🚀 Iniciando Ciclo de Isótopos..."
                    // Sobe apenas os serviços do reator
                    sh 'docker-compose up -d --build engine_python transport_go envoy redis db_vector rabbitmq'
                    
                    echo "Aguardando estabilização da Curvatura de Ricci (1.2006)..."
                    sleep 30 
                }
            }
        }

        stage('⚖️ Auditoria ABNT-ZETA-1200') {
            steps {
                // Chama o braço armado para validar a hibridização
                sh 'chmod +x infra/envoy/audit_zeta.sh'
                sh './infra/envoy/audit_zeta.sh'
            }
        }

        stage('💎 Certificação de Soberania') {
            steps {
                script {
                    echo "🔓 [SOBERANIA] 1.2 Confirmado. Carimbando Versão Gold no GitHub."
                    
                    sh "git tag -d v1.2-soberano || true"
                    sh "git tag -a v1.2-soberano -m '💎 Veredito: 1+1=0 Confirmado via Geometria de Ricci'"
                    
                    withCredentials([usernamePassword(credentialsId: "${GIT_CRED_ID}", passwordVariable: 'GIT_PASSWORD', usernameVariable: 'GIT_USERNAME')]) {
                        // Push seguro via HTTPS usando o Token
                        sh "git push https://${GIT_PASSWORD}@://github.com --tags --force"
                    }
                }
            }
        }
    }

    post {
        always {
            // Coloca o reator em repouso, mas mantém o Jenkins em guarda (UP)
            sh 'docker-compose stop engine_python transport_go envoy redis db_vector rabbitmq || true'
            echo "🏁 Auditoria Finalizada. Reator desligado, Auditor Supremo online."
        }
    }
}


