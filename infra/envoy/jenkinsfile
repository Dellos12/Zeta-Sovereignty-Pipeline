pipeline {
    agent any
    
    environment {
        // ID da credencial que você criou no Jenkins (Kind: Username with password)
        GIT_CRED_ID = 'github-token-zeta'
        // URL real do seu repositório no GitHub
        REPO_URL = 'git@github.com:Dellos12/Zeta-Sovereignty-Pipeline.git'
    }

    stages {
        stage('🧬 Clonagem e Sincronia') {
            steps {
                // O Jenkins usa o Token para garantir o acesso ao Manifold
                checkout scm
            }
        }

        stage('🔥 Ignição do Reator') {
            steps {
                // Sobe as 7 portas do Manifold Zeta
                sh 'docker compose up -d --build'
                echo "Aguardando estabilização da Curvatura de Ricci..."
                sleep 20 // Tempo para o SentenceTransformers hibridizar
            }
        }

        stage('⚖️ Auditoria ABNT-ZETA-1200') {
            steps {
                // Chama o braço armado para validar o 1.2006
                sh 'chmod +x infra/envoy/audit_zeta.sh'
                sh './infra/envoy/audit_zeta.sh'
            }
        }

        stage('💎 Certificação de Soberania') {
            steps {
                script {
                    echo "🔓 [SOBERANIA] 1.2 Confirmado. Carimbando Versão Gold no GitHub."
                    
                    // Cria a TAG localmente (remove se já existir para evitar conflito)
                    sh "git tag -d v1.2-soberano || true"
                    sh "git tag -a v1.2-soberano -m '💎 Veredito: 1+1=0 Confirmado via Geometria de Ricci'"
                    
                    // Empurra a Tag para o GitHub usando as credenciais injetadas
                    withCredentials([usernamePassword(credentialsId: "${GIT_CRED_ID}", passwordVariable: 'GIT_PASSWORD', usernameVariable: 'GIT_USERNAME')]) {
                        // Construção da URL com Token para o Push Seguro
                        sh "git push https://${GIT_USERNAME}:${GIT_PASSWORD}@://github.com --tags --force"
                    }
                }
            }
        }
    }

    post {
        always {
            // Retorna o Hiperplano ao repouso para o próximo build
            sh 'docker compose down'
            echo "🏁 Auditoria Finalizada. Manifold em estado de vácuo."
        }
    }
}

