pipeline {
    agent any
    environment {
        GIT_CRED_ID = 'github-token-zeta'
        REPO_URL = 'https://github.com'
    }

    stages {
        stage('🧬 1. Saneamento e Simetria') {
            steps {
                script {
                    echo "🧹 [LUA_ENGINE] Limpando pastas fantasmas e auditando caminhos..."
                    sh 'docker rm -f engine_python transport_go envoy redis db_vector rabbitmq || true'
                    
                    checkout scm

                    // LÓGICA DE GOVERNANÇA: Se o Docker criou uma pasta no lugar do arquivo, o shell remove.
                    sh """
                    [ -d "infra/envoy/envoy.yaml" ] && sudo rm -rf infra/envoy/envoy.yaml || true
                    [ -d "infra/envoy/governo.lua" ] && sudo rm -rf infra/envoy/governo.lua || true
                    """
                    
                    sh 'chmod +x infra/envoy/audit_zeta.sh'
                    sh 'chmod 644 infra/envoy/governo.lua'
                }
            }
        }

        stage('🔥 2. Ignição do Reator') {
            steps {
                script {
                    echo "🚀 [SEQUÊNCIA] Iniciando Reator com Montagem Segura..."
                    sh 'docker-compose up -d --build --remove-orphans'
                    echo "⏳ Aguardando estabilização (35s)..."
                    sleep 35
                }
            }
        }

        stage('⚖️ 3. Veredito via Governo Lua') {
            steps {
                script {
                    // Captura o gradiente do Reator
                    def gradiente = sh(script: "docker exec engine_python python3 -c 'from utils.meta_expert import MetaExpert; print(MetaExpert.calcular_funcao_limite())'", returnStdout: true).trim()
                    
                    echo "🧠 Consultando governo.lua sobre o Gradiente: ${gradiente}"
                    // O Jenkins executa o governo.lua com o nome correto
                    def luaExitCode = sh(script: "lua infra/envoy/governo.lua ${gradiente}", returnStatus: true)

                    if (luaExitCode == 0) {
                        echo "🔓 [BRAÇO] Governo Lua autorizou a Certificação."
                    } else {
                        error "❌ [BRAÇO] O Governo detectou Ruptura. Build Abortado."
                    }
                }
            }
        }
    }

    post {
        always {
            sh 'docker-compose stop engine_python transport_go envoy redis db_vector rabbitmq || true'
        }
    }
}

