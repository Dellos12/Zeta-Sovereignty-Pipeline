
pipeline {
    agent any

    environment {
        // Credenciais e Repositório
        GIT_CRED_ID = 'github-token-zeta'
        REPO_URL    = 'https://github.com/Dellos12/Zeta-Sovereignty-Pipeline'

        // Ajustado: Pasta relativa dentro do repositório Git
        PASTA_RUBY        = "Manifold" 
        REDE_REAL         = "workspace_ressonancia_net"

        // Variáveis de Soberania
        DB_HOST     = "db_vector"
        DB_USER     = "postgres"
        DB_PASSWORD = "password"
        DB_NAME     = "manifold_development"
        REDIS_URL   = "redis://redis:6379/1"
        RAILS_ENV   = "production"

        // Necessária para o Rails 8.1+ em Production
        SECRET_KEY_BASE = "1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef"
    }

    stages {
        stage('1. Sincronização da Malha Oficial') {
            steps {
                echo "--- Garantindo que a Engine e os Bancos estão UP ---"
                // Removido dir() absoluto: usa a raiz do checkout por padrão
                sh 'docker-compose --profile pipeline up -d'
            }
        }

        stage('2. Acoplamento e Injeção de Segurança') {
            steps {
                // Entra na pasta do app para o build
                dir("${PASTA_RUBY}") {
                    echo "--- Reconstruindo a Peça Ruby (Manifold) ---"
                    sh 'docker build -t manifold_underground .'
                }
                
                script {
                    echo "--- Resetando e Alinhando Container em /rails ---"
                    sh 'docker rm -f manifold_app || true'
                    
                    // CORREÇÃO FINAL: Removido o volume (-v) para evitar erro 'bin/rails not found'
                    sh """
                        docker run -d --name manifold_app \
                        --network ${REDE_REAL} \
                        -w /rails \
                        -e DB_HOST=${DB_HOST} \
                        -e DB_USER=${DB_USER} \
                        -e DB_PASSWORD=${DB_PASSWORD} \
                        -e DB_NAME=${DB_NAME} \
                        -e REDIS_URL=${REDIS_URL} \
                        -e RAILS_ENV=${RAILS_ENV} \
                        -e SECRET_KEY_BASE=${SECRET_KEY_BASE} \
                        --entrypoint /bin/bash \
                        manifold_underground -c "tail -f /dev/null"
                    """
                    
                    echo "--- Destravando bin/rails ---"
                    sh 'docker exec -u root manifold_app chmod +x bin/rails'
                }
            }
        }

        stage('3. Prontidão para o Console Zeta') {
            steps {
                echo "--- ENGRENAGEM ALINHADA E BLINDADA ---"
                echo "Container rodando de forma isolada e segura."
                echo "DIGITE AGORA NO SEU TERMINAL:"
                echo "docker exec -it manifold_app bin/rails c"
            }
        }
    }
}

