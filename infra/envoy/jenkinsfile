pipeline {
    agent any
    
    environment {
        // Credencial 'github-token-zeta' deve ser 'Username with password'
        GIT_CRED_ID = 'github-token-zeta'
        REPO_URL = 'https://github.com/Dellos12/Zeta-Sovereignty-Pipeline'
    }

    stages {
        stage('🧬 1. Saneamento e Clonagem') {
            steps {
                script {
                    echo "🧹 [SEQUÊNCIA DE MONTAGEM] Limpando o campo para a hibridização..."
                    // Para e remove containers por NOME para garantir que as portas 8080/50051 fiquem livres
                    sh 'docker rm -f engine_python transport_go envoy redis db_vector rabbitmq || true'
                    checkout scm
                }
            }
        }

        stage('🔥 2. Ignição do Reator (Músculo)') {
            steps {
                script {
                    echo "🚀 [SEQUÊNCIA DE MONTAGEM] Injetando carga no Reator..."
                    // Sobe apenas os operários. O Jenkins (Auditor) já está UP.
                    sh 'docker-compose up -d --build --remove-orphans engine_python transport_go envoy redis db_vector rabbitmq'
                    
                    echo "⏳ Aguardando estabilização da Curvatura (1.2006)..."
                    sleep 35 
                }
            }
        }

        stage('⚖️ 3. Auditoria ABNT-ZETA-1200 (Cérebro)') {
            steps {
                echo "📏 [SEQUÊNCIA DE MONTAGEM] Validando a Geometria de Ricci..."
                sh 'chmod +x infra/envoy/audit_zeta.sh'
                sh './infra/envoy/audit_zeta.sh'
            }
        }

        stage('💎 4. Certificação de Soberania (Lei)') {
            steps {
                script {
                    echo "🔓 [SOBERANIA] 1.2 Confirmado. Carimbando Versão Gold."
                    
                    sh "git tag -d v1.2-soberano || true"
                    sh "git tag -a v1.2-soberano -m '💎 Veredito: 1+1=0 Confirmado via Geometria de Ricci'"
                    
                    withCredentials([usernamePassword(credentialsId: "${GIT_CRED_ID}", passwordVariable: 'GIT_PASSWORD', usernameVariable: 'GIT_USERNAME')]) {
                        // URL Corrigida para o Push soberano
                        sh "git push https://${GIT_PASSWORD}@://github.com --tags --force"
                    }
                }
            }
        }
    }

    post {
        always {
            echo "🏁 [REPOUSO] Retornando o Manifold ao estado adiabático."
            sh 'docker-compose stop engine_python transport_go envoy redis db_vector rabbitmq || true'
        }
    }
}

