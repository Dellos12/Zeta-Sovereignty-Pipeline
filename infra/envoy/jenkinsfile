
pipeline {
    agent any
    environment {
        GIT_CRED_ID = 'github-token-zeta'
        REPO_URL = 'https://github.com/Dellos12/Zeta-Sovereignty-Pipeline'
    }

    stages {
        stage('🧬 Preparação') {
            steps {
                script {
                    echo "🧹 Limpando containers antigos..."
                    sh 'docker rm -f engine_python transport_go envoy redis db_vector rabbitmq || true'
                    
                    checkout scm

                    sh """
                    [ -d "infra/envoy/envoy.yaml" ] && sudo rm -rf infra/envoy/envoy.yaml || true
                    [ -d "infra/envoy/governo.lua" ] && sudo rm -rf infra/envoy/governo.lua || true
                    """

                    sh 'chmod +x infra/envoy/audit_zeta.sh'
                    sh 'chmod 644 infra/envoy/governo.lua'
                }
            }
        }

        stage('🔥 Subir Banco Vetorial') {
            steps {
                script {
                    sh 'cd /workspace && docker-compose --profile pipeline up -d db_vector'
                }
            }
        }

        stage('🔥 Subir Redis') {
            steps {
                script {
                    sh 'cd /workspace && docker-compose --profile pipeline up -d redis'
                }
            }
        }

        stage('🔥 Subir RabbitMQ') {
            steps {
                script {
                    sh 'cd /workspace && docker-compose --profile pipeline up -d rabbitmq'
                }
            }
        }

        stage('🔥 Subir Engine Python') {
            steps {
                script {
                    sh 'cd /workspace && docker-compose --profile pipeline up -d engine_python'
                }
            }
        }

        stage('🔥 Subir Transport Go') {
            steps {
                script {
                    sh 'cd /workspace && docker-compose --profile pipeline up -d transport_go'
                }
            }
        }

        stage('🔥 Subir Envoy') {
            steps {
                script {
                    sh 'cd /workspace && docker-compose --profile pipeline up -d envoy'
                }
            }
        }

        stage('⚖️ Veredito via Governo Lua') {
            steps {
                script {
                    def gradiente = sh(
                        script: "docker exec engine_python python3 -c 'from utils.meta_expert import MetaExpert; print(MetaExpert.calcular_funcao_limite())'",
                        returnStdout: true
                    ).trim()

                    echo "🧠 Consultando governo.lua sobre o Gradiente: ${gradiente}"
                    def luaExitCode = sh(script: "lua infra/envoy/governo.lua ${gradiente}", returnStatus: true)

                    if (luaExitCode == 0) {
                        echo "✅ Governo Lua autorizou a Certificação."
                    } else {
                        error "❌ Ruptura detectada. Build Abortado."
                    }
                }
            }
        }
    }

    post {
        always {
            sh 'cd /workspace && docker-compose stop engine_python transport_go envoy redis db_vector rabbitmq || true'
        }
    }
}
