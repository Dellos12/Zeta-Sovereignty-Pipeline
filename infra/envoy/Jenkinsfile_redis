pipeline {
    agent any
    stages {
        stage('Subir Banco Vetorial') {
            steps {
                script {
                    sh 'cd /workspace && docker-compose --profile pipeline up -d db_vector'
                }
            }
        }
    }
    post {
        always {
            sh 'cd /workspace && docker-compose stop db_vector || true'
        }
    }
}

